# syntax=docker/dockerfile:1

############################
# 1. Build stage
############################
FROM pytorch/pytorch:2.10.0-cuda12.6-cudnn9-runtime AS builder

LABEL maintainer="Atsushi TAKEDA @takedarts"

ENV DEBIAN_FRONTEND=noninteractive
WORKDIR /opt/gokaku

# Install build dependencies
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        git make g++ wget ca-certificates \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Install cython
RUN pip install --no-cache-dir --break-system-packages cython

# Install CUDA toolkit 12.6
RUN wget https://developer.download.nvidia.com/compute/cuda/repos/ubuntu2404/x86_64/cuda-keyring_1.1-1_all.deb \
    && dpkg -i cuda-keyring_1.1-1_all.deb \
    && rm cuda-keyring_1.1-1_all.deb \
    && apt-get update \
    && apt-get install -y --no-install-recommends cuda-toolkit-12.6 \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Clone the repository and build the project
RUN git clone --depth=1 https://github.com/takedarts/gokaku . \
    && python3 src/build.py \
    && rm -rf src/deepshogi/native/build

############################
# 2. Runtime stage
############################
FROM pytorch/pytorch:2.10.0-cuda12.6-cudnn9-runtime AS runtime

WORKDIR /opt/gokaku

# Copy the built project from the builder stage
COPY --from=builder /opt/gokaku /opt/gokaku

# Copy the run script
COPY --chmod=755 run.sh /opt/run.sh
COPY --chmod=755 pnsolver.sh /opt/pnsolver.sh

WORKDIR /workspace

# Set the default command to display help
CMD ["/opt/run.sh", "--help"]
